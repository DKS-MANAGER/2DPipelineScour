#!/bin/bash
set -e

. "$WM_PROJECT_DIR/bin/tools/RunFunctions"

echo "=== Resuming Phase 1 ==="
# Resume Phase 1 from latestTime (0.5s) and append to log.phase1
mpirun -np 6 sedExnerFoam -parallel >> log.phase1 2>&1

echo "=== Phase 2 ==="
sed -i 's/morphoAccFactor.*/morphoAccFactor   0.1;/' constant/bedloadProperties
sed -i 's/avalanche.*/avalanche         on;/' constant/bedloadProperties
mpirun -np 6 sedExnerFoam -parallel > log.phase2 2>&1

echo "=== Reconstructing results ==="
reconstructParMesh -latestTime > log.reconstructParMesh 2>&1
reconstructPar > log.reconstructPar 2>&1

rm -rf processor*
echo "=== Finished Resumed Simulation ==="
